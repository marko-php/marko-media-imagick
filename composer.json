{
    "name": "marko/media-imagick",
    "description": "ImageMagick image processing driver for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/media": "self.version",
        "ext-imagick": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\MediaImagick\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\MediaImagick\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
